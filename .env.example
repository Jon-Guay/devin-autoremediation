# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_SOURCE_REPO=apache/superset
GITHUB_FORK_REPO=your-username/superset

# Anthropic (used for AI issue scoring)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Devin
DEVIN_API_KEY=...

# Grafana Cloud (from your stack's Details page)
GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-prod-XX-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USERNAME=123456
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=123456
GRAFANA_CLOUD_API_KEY=glc_...

# Webhook server
WEBHOOK_SECRET=changeme
SESSION_STORE_PATH=/data/sessions.json

# Exporter
EXPORTER_PORT=9090
EXPORTER_REFRESH_INTERVAL=60
DEVIN_METRICS_WINDOW_DAYS=30
